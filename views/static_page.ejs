<!DOCTYPE html>
<html lang="bg">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> | БФСА</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@600;700&family=Montserrat:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
  <style>
    body { font-family: Montserrat, sans-serif; }
    .display { font-family: 'Cormorant Garamond', serif; }
  </style>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
</head>
<body class="min-h-screen bg-[#fbf8f1] text-[#26201c]">
  <main>
    <section class="bg-[#063d2d] px-6 py-16 text-white">
      <div class="mx-auto max-w-7xl">
        <a href="/" class="inline-flex items-center rounded-xl border border-[#bd8e3b]/40 px-4 py-2 text-sm font-black text-[#ead8b5] transition hover:bg-white/10">
        <span class="sm:hidden">← Начало</span>
        <span class="hidden sm:inline">← Обратно към началната страница</span>
      </a>
        <p class="mt-8 text-xs font-black uppercase tracking-[.22em] text-[#bd8e3b]"><%= eyebrow %></p>
        <h1 class="display mt-3 text-5xl font-bold uppercase tracking-wide md:text-6xl"><%= title %></h1>
        <p class="mt-5 max-w-3xl text-white/75"><%= description %></p>
      </div>
    </section>

    <section class="px-6 py-12">
      <div class="mx-auto max-w-7xl">
        <% if (typeof cards !== 'undefined' && cards && cards.length) { %>
          <div class="grid gap-6 md:grid-cols-3">
            <% cards.forEach(card => { %>
              <article class="rounded-3xl border border-[#ead8b5] bg-white p-7 shadow-lg">
                <div class="text-4xl text-[#bd8e3b]"><%- card.icon %></div>
                <h2 class="mt-5 text-xl font-black text-[#063d2d]"><%= card.title %></h2>
                <p class="mt-3 text-sm leading-6 text-[#6e655e]"><%= card.text %></p>
              </article>
            <% }) %>
          </div>
        <% } %>

        <% if (typeof documents !== 'undefined' && documents && documents.length) { %>
          <div class="mt-10 grid gap-5">
            <% documents.forEach(doc => { %>
              <article class="flex flex-col justify-between gap-4 rounded-2xl border border-[#ead8b5] bg-white p-6 shadow-md md:flex-row md:items-center">
                <div>
                  <p class="text-xs font-black uppercase tracking-[.18em] text-[#bd8e3b]"><%= typeof categoryLabel === 'function' ? categoryLabel(doc.category) : doc.category %></p>
                  <h3 class="mt-1 text-xl font-black text-[#063d2d]"><%= doc.title %></h3>
                  <% if (doc.description) { %><p class="mt-2 text-sm text-[#6e655e]"><%= doc.description %></p><% } %>
                </div>
                <a href="<%= doc.file_path %>" target="_blank" class="rounded-xl bg-[#0f6043] px-5 py-3 text-center text-sm font-bold text-white">Изтегли PDF</a>
              </article>
            <% }) %>
          </div>
        <% } else if (typeof documents !== 'undefined') { %>
          <div class="mt-10 rounded-3xl border border-[#ead8b5] bg-white p-10 text-center shadow-lg">
            <h2 class="text-xl font-black text-[#063d2d] sm:text-2xl">Все още няма качени документи</h2>
            <p class="mt-3 text-[#6e655e]">Когато бъдат добавени от админ панела, ще се появят тук автоматично.</p>
          </div>
        <% } %>

      </div>
    </section>
  </main>
</body>
</html>
