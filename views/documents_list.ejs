<!DOCTYPE html>
<html lang="bg">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Документи | БФСА</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@600;700&family=Montserrat:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
  <style>body{font-family:Montserrat,sans-serif}.display{font-family:'Cormorant Garamond',serif}</style>
</head>
<body class="min-h-screen bg-[#fbf8f1] text-[#26201c]">
  <header class="bg-[#063d2d] px-6 py-12 text-white">
    <div class="mx-auto max-w-6xl">
      <a href="/" class="inline-flex items-center rounded-xl border border-[#bd8e3b]/40 px-4 py-2 text-sm font-black text-[#ead8b5] transition hover:bg-white/10">
        <span class="sm:hidden">← Начало</span>
        <span class="hidden sm:inline">← Обратно към началната страница</span>
      </a>
      <p class="mt-8 text-xs font-black uppercase tracking-[.22em] text-[#bd8e3b]">Официален архив</p>
      <h1 class="display mt-3 text-4xl sm:text-5xl font-bold uppercase tracking-wide md:text-6xl">Документи и правила</h1>
      <p class="mt-5 max-w-3xl text-white/75">Официален архив на Българската федерация по спортна акробатика.</p>
    </div>
  </header>

  <main class="mx-auto max-w-6xl px-6 py-12">

    <% categories.forEach(cat => { const docs = documents.filter(d => d.category === cat.value); if (docs.length) { %>
      <section class="mb-10 rounded-3xl bg-white p-4 sm:p-6 shadow-xl">
        <div class="mb-5 flex items-center justify-between border-b border-[#ead8b5] pb-4">
          <h2 class="text-xl font-black text-[#063d2d] sm:text-2xl"><%= cat.label %></h2>
          <span class="rounded-full bg-[#ead8b5] px-3 py-1 text-xs font-bold"><%= docs.length %></span>
        </div>
        <div class="grid gap-4 md:grid-cols-2">
          <% docs.forEach(doc => { %>
            <article class="rounded-2xl border border-[#ead8b5] bg-[#fffdf8] p-5 transition hover:-translate-y-1 hover:shadow-lg">
              <div class="mb-3 flex items-start justify-between gap-3">
                <h3 class="text-lg font-black text-[#063d2d]"><%= doc.title %></h3>
                <span class="shrink-0 rounded-full bg-[#b81824] px-2 py-1 text-xs font-black text-white">PDF</span>
              </div>
              <% if (doc.description) { %><p class="mb-4 text-sm text-[#6e655e]"><%= doc.description %></p><% } %>
              <div class="flex items-center justify-between gap-3">
                <span class="text-xs text-[#6e655e]"><%= new Date(doc.created_at).toLocaleDateString('bg-BG') %></span>
                <a href="<%= doc.file_path %>" target="_blank" class="rounded-xl bg-[#0f6043] px-4 py-2 text-sm font-bold text-white hover:bg-[#063d2d]">Отвори PDF</a>
              </div>
            </article>
          <% }) %>
        </div>
      </section>
    <% } }) %>

    <% if (!documents.length) { %>
      <div class="rounded-3xl border border-dashed border-[#bd8e3b] bg-white p-10 text-center text-[#6e655e]">Все още няма качени документи.</div>
    <% } %>
  </main>
</body>
</html>
