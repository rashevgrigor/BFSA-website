<!DOCTYPE html>
<html lang="bg">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Всички новини | БФСА</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@600;700&family=Montserrat:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
  <style>
    body { font-family: Montserrat, sans-serif; }
    .display { font-family: 'Cormorant Garamond', serif; }
  </style>
</head>
<body class="min-h-screen bg-[#fbf8f1] text-[#26201c]">
  <header class="border-b border-[#ead8b5] bg-white/90 px-5 py-5 shadow-sm">
    <div class="mx-auto flex max-w-7xl items-center justify-between gap-4">
      <a href="/" class="font-black uppercase tracking-[.16em] text-[#063d2d]">БФСА</a>
      <nav class="flex items-center gap-5 text-sm font-bold text-[#0f6043]">
        <a href="/" class="hover:underline">Начало</a>
        <a href="/login" class="rounded-xl border border-[#bd8e3b]/40 px-4 py-2 hover:bg-[#bd8e3b] hover:text-white">Вход</a>
      </nav>
    </div>
  </header>

  <main class="mx-auto max-w-7xl px-4 py-8 sm:px-5 sm:py-12">
    <div class="mb-10 text-center">
      <p class="text-xs font-black uppercase tracking-[.24em] text-[#bd8e3b]">Българска Федерация по Спортна Акробатика</p>
      <h1 class="display mt-3 text-4xl sm:text-5xl font-bold uppercase text-[#063d2d]">Всички новини</h1>
      <p class="mx-auto mt-4 max-w-2xl text-sm leading-7 text-[#6e655e]">Последни публикации, съобщения, резултати и важна информация от БФСА.</p>
    </div>

    <% if (!news.length) { %>
      <section class="rounded-3xl bg-white p-10 text-center shadow-xl ring-1 ring-[#ead8b5]">
        <h2 class="text-xl font-black text-[#063d2d] sm:text-2xl">Все още няма публикувани новини</h2>
        <p class="mt-3 text-[#6e655e]">Администраторите могат да добавят новини от админ панела.</p>
      </section>
    <% } else { %>
      <section class="grid gap-4 sm:gap-4 sm:p-6 md:grid-cols-2 lg:grid-cols-3">
        <% news.forEach(article => { %>
          <article class="overflow-hidden rounded-3xl bg-white shadow-xl ring-1 ring-[#ead8b5] transition hover:-translate-y-1 hover:shadow-2xl">
            <% if (article.image_path) { %>
              <img src="<%= article.image_path %>" alt="<%= article.title %>" class="h-56 w-full object-cover">
            <% } else { %>
              <div class="grid h-56 place-items-center bg-[#063d2d] text-white">
                <span class="text-4xl sm:text-5xl">📰</span>
              </div>
            <% } %>
            <div class="p-4 sm:p-6">
              <p class="text-[10px] font-black uppercase tracking-[.18em] text-[#bd8e3b]"><%= article.category || 'Новини' %> · <%= new Date(article.created_at).toLocaleDateString('bg-BG') %></p>
              <h2 class="mt-3 text-xl font-black leading-7 text-[#063d2d]"><%= article.title %></h2>
              <p class="mt-3 line-clamp-3 text-sm leading-6 text-[#6e655e]"><%= article.summary %></p>
              <a href="/news/<%= article.slug %>" class="mt-6 inline-flex text-xs font-extrabold uppercase tracking-[.14em] text-[#0f6043] hover:underline">Прочети повече →</a>
            </div>
          </article>
        <% }) %>
      </section>
    <% } %>
  </main>
</body>
</html>
