<!DOCTYPE html>
<html lang="bg">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= club ? 'Edit Club' : 'Add Club' %> | БФСА</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="min-h-screen bg-[#fbf8f1] text-[#26201c]">
  <main class="mx-auto max-w-3xl px-4 py-6 sm:px-6 sm:py-8">
    <div class="mb-6 flex items-center justify-between">
      <div>
        <h1 class="text-2xl font-black text-[#063d2d] sm:text-3xl"><%= club ? 'Edit Club' : 'Add Club' %></h1>
        <p class="text-sm text-gray-600">Club profile, city filter data, logo and contact details.</p>
      </div>
      <a href="/admin/clubs" class="rounded-xl border px-4 py-2 font-bold text-[#063d2d]">Back</a>
    </div>

    <% if (error) { %><div class="mb-5 rounded-xl bg-red-50 p-3 text-sm text-red-700"><%= error %></div><% } %>

    <form action="<%= club ? '/admin/clubs/' + club.id + '/edit' : '/admin/clubs' %>" method="POST" enctype="multipart/form-data" class="space-y-5 rounded-3xl bg-white p-6 shadow-xl">
      <div class="grid gap-4 md:grid-cols-2">
        <label class="block text-sm font-bold">Club Name *
          <input name="name" required value="<%= club ? club.name : '' %>" class="mt-1 w-full rounded-xl border p-3">
        </label>
        <label class="block text-sm font-bold">City *
          <input name="city" required value="<%= club ? club.city : '' %>" placeholder="София" class="mt-1 w-full rounded-xl border p-3">
        </label>
      </div>

      <div class="grid gap-4 md:grid-cols-2">
        <label class="block text-sm font-bold">Coach
          <input name="coach" value="<%= club ? club.coach : '' %>" class="mt-1 w-full rounded-xl border p-3">
        </label>
        <label class="block text-sm font-bold">Address / Hall
          <input name="address" value="<%= club ? club.address : '' %>" class="mt-1 w-full rounded-xl border p-3">
        </label>
      </div>

      <div class="grid gap-4 md:grid-cols-2">
        <label class="block text-sm font-bold">Phone
          <input name="phone" value="<%= club ? club.phone : '' %>" class="mt-1 w-full rounded-xl border p-3">
        </label>
        <label class="block text-sm font-bold">Email
          <input name="email" type="email" value="<%= club ? club.email : '' %>" class="mt-1 w-full rounded-xl border p-3">
        </label>
      </div>

      <div class="grid gap-4 md:grid-cols-3">
        <label class="block text-sm font-bold">Website
          <input name="website" value="<%= club ? club.website : '' %>" placeholder="https://..." class="mt-1 w-full rounded-xl border p-3">
        </label>
        <label class="block text-sm font-bold">Instagram
          <input name="instagram" value="<%= club ? club.instagram : '' %>" placeholder="https://..." class="mt-1 w-full rounded-xl border p-3">
        </label>
        <label class="block text-sm font-bold">Facebook
          <input name="facebook" value="<%= club ? club.facebook : '' %>" placeholder="https://..." class="mt-1 w-full rounded-xl border p-3">
        </label>
      </div>

      <label class="block text-sm font-bold">Short Description
        <input name="short_description" value="<%= club ? club.short_description : '' %>" placeholder="Кратко описание за банера" class="mt-1 w-full rounded-xl border p-3">
      </label>

      <label class="block text-sm font-bold">Full Description
        <textarea name="description" rows="7" class="mt-1 w-full rounded-xl border p-3"><%= club ? club.description : '' %></textarea>
      </label>

      <label class="block text-sm font-bold">Logo Image
        <input name="logo" type="file" accept="image/*" class="mt-1 w-full rounded-xl border p-3">
      </label>

      <% if (club && club.logo_path) { %>
        <div>
          <p class="text-sm font-bold">Current logo:</p>
          <img src="<%= club.logo_path %>" class="mt-2 h-20 w-20 rounded-xl object-cover ring-1 ring-[#ead8b5]">
        </div>
      <% } %>

      <button class="w-full rounded-xl bg-[#0f6043] px-4 py-3 font-black text-white hover:bg-[#063d2d]">
        <%= club ? 'Save Changes' : 'Create Club' %>
      </button>
    </form>
  </main>
</body>
</html>
