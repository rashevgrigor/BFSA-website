<!DOCTYPE html>
<html lang="bg">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= article.title %> | БФСА</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="min-h-screen bg-[#fbf8f1] text-[#26201c]">
  <main class="mx-auto max-w-4xl px-6 py-10">
    <a href="/news" class="text-sm font-bold text-[#0f6043] hover:underline">← Всички новини</a>
    <article class="mt-6 overflow-hidden rounded-3xl bg-white shadow-2xl">
      <% if (article.image_path) { %>
        <img src="<%= article.image_path %>" class="h-80 w-full object-cover">
      <% } %>
      <div class="p-8 md:p-10">
        <p class="text-xs font-black uppercase tracking-[.14em] text-[#bd8e3b]"><%= article.category %> · <%= new Date(article.created_at).toLocaleDateString('bg-BG') %></p>
        <h1 class="mt-3 text-4xl font-black text-[#063d2d]"><%= article.title %></h1>
        <p class="mt-5 text-lg font-semibold text-gray-700"><%= article.summary %></p>
        <div class="mt-8 whitespace-pre-line leading-8 text-gray-800"><%= article.content %></div>
      </div>
    </article>
  </main>
</body>
</html>
