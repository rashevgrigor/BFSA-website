<!DOCTYPE html>
<html lang="bg">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Национален отбор | БФСА</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@600;700&family=Montserrat:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
  <style>body{font-family:Montserrat,sans-serif}.display{font-family:'Cormorant Garamond',serif}</style>
</head>
<body class="min-h-screen bg-[#fbf8f1] text-[#26201c]">
  <header class="bg-[#063d2d] px-6 py-16 text-white">
    <div class="mx-auto max-w-7xl">
      <a href="/" class="inline-flex items-center rounded-xl border border-[#bd8e3b]/40 px-4 py-2 text-sm font-black text-[#ead8b5] transition hover:bg-white/10">
        <span class="sm:hidden">← Начало</span>
        <span class="hidden sm:inline">← Обратно към началната страница</span>
      </a>
      <p class="mt-8 text-xs font-black uppercase tracking-[.22em] text-[#bd8e3b]">БФСА</p>
      <h1 class="display mt-3 text-4xl sm:text-5xl font-bold uppercase tracking-wide md:text-6xl">Национален отбор</h1>
      <p class="mt-5 max-w-3xl text-white/75">Представителните състави на България по спортна акробатика.</p>
    </div>
  </header>

  <main class="mx-auto max-w-7xl px-6 py-12">
    <% ageGroups.forEach(group => { const groupEntries = entries.filter(e => e.age_group === group.value); %>
      <details class="mb-6 overflow-hidden rounded-3xl border border-[#ead8b5] bg-white shadow-lg" <%= groupEntries.length ? 'open' : '' %>>
        <summary class="cursor-pointer bg-[#fffdf8] px-6 py-5 text-xl font-black text-[#063d2d] hover:bg-[#ead8b5]/40">
          🇧🇬 <%= group.label %>
          <span class="ml-2 text-sm font-bold text-[#6e655e]">(<%= groupEntries.length %>)</span>
        </summary>
        <div class="space-y-8 p-4 sm:p-6">
          <% categories.forEach(cat => { const categoryEntries = groupEntries.filter(e => e.category === cat.value); if (categoryEntries.length) { %>
            <section>
              <h2 class="mb-4 text-sm font-black uppercase tracking-[.18em] text-[#bd8e3b]"><%= cat.label %></h2>
              <div class="grid gap-5 md:grid-cols-2">
                <% categoryEntries.forEach(entry => { %>
                  <a href="/national-team/<%= entry.slug %>" class="group overflow-hidden rounded-3xl border border-[#ead8b5] bg-[#fbf8f1] shadow-md transition hover:-translate-y-1 hover:shadow-xl">
                    <% if (entry.photo_path) { %>
                      <img src="<%= entry.photo_path %>" class="h-56 w-full object-cover">
                    <% } else { %>
                      <div class="grid h-56 place-items-center bg-[#ead8b5] text-4xl sm:text-5xl font-black text-[#063d2d]">БФСА</div>
                    <% } %>
                    <div class="p-5">
                      <p class="text-xs font-black uppercase tracking-[.18em] text-[#bd8e3b]"><%= cat.label %></p>
                      <h3 class="mt-1 text-2xl font-black text-[#063d2d]"><%= entry.title %></h3>
                      <p class="mt-2 text-sm font-bold text-[#26201c]"><%= [entry.athlete1, entry.athlete2, entry.athlete3, entry.athlete4].filter(Boolean).join(' · ') %></p>
                      <p class="mt-2 text-sm text-[#6e655e]"><%= entry.club || 'Клуб не е посочен' %><% if (entry.coach) { %> · Coach: <%= entry.coach %><% } %></p>
                      <span class="mt-4 inline-block text-sm font-black text-[#0f6043] group-hover:underline">Виж профил →</span>
                    </div>
                  </a>
                <% }) %>
              </div>
            </section>
          <% } }) %>
          <% if (!groupEntries.length) { %>
            <div class="rounded-2xl bg-[#fbf8f1] p-8 text-center text-[#6e655e]">Все още няма добавени състави за тази възрастова група.</div>
          <% } %>
        </div>
      </details>
    <% }) %>
  </main>
</body>
</html>
