<!DOCTYPE html>
<html lang="bg">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= document ? 'Edit Document' : 'Upload Document' %> | БФСА Admin</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="min-h-screen bg-[#fbf8f1] text-[#26201c]">
  <header class="border-b bg-white/90 px-4 py-4 shadow-sm sm:px-6">
    <div class="mx-auto flex max-w-4xl flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
      <div>
        <h1 class="text-xl font-black text-[#063d2d] sm:text-2xl"><%= document ? 'Edit Document' : 'Upload Document' %></h1>
        <p class="text-sm text-gray-600">PDF files only.</p>
      </div>
      <a href="/admin/documents" class="rounded-xl border px-4 py-2 font-bold text-[#063d2d]">Back</a>
    </div>
  </header>

  <main class="mx-auto max-w-4xl px-4 py-6 sm:px-6 sm:py-8">
    <form action="<%= document ? '/admin/documents/' + document.id + '/edit' : '/admin/documents' %>" method="POST" enctype="multipart/form-data" class="space-y-5 rounded-3xl bg-white p-4 shadow-xl sm:p-6">
      <% if (error) { %><div class="rounded-xl bg-red-50 p-3 text-sm text-red-700"><%= error %></div><% } %>

      <label class="block text-sm font-bold text-gray-700">Title
        <input name="title" value="<%= document ? document.title : '' %>" required class="mt-1 w-full rounded-xl border p-3 outline-none focus:ring-2 focus:ring-[#bd8e3b]">
      </label>

      <label class="block text-sm font-bold text-gray-700">Category
        <select name="category" class="mt-1 w-full rounded-xl border p-3 outline-none focus:ring-2 focus:ring-[#bd8e3b]">
          <% categories.forEach(cat => { %>
            <option value="<%= cat.value %>" <%= document && document.category === cat.value ? 'selected' : '' %>><%= cat.label %></option>
          <% }) %>
        </select>
      </label>

      <label class="block text-sm font-bold text-gray-700">Description
        <textarea name="description" rows="4" class="mt-1 w-full rounded-xl border p-3 outline-none focus:ring-2 focus:ring-[#bd8e3b]"><%= document ? document.description : '' %></textarea>
      </label>

      <label class="block text-sm font-bold text-gray-700">PDF File <%= document ? '(leave empty to keep current file)' : '' %>
        <input name="file" type="file" accept="application/pdf,.pdf" <%= document ? '' : 'required' %> class="mt-1 w-full rounded-xl border p-3">
      </label>

      <% if (document && document.file_path) { %>
        <div class="rounded-2xl bg-[#fbf8f1] p-4 text-sm">
          Current file: <a href="<%= document.file_path %>" target="_blank" class="font-bold text-[#0f6043] hover:underline"><%= document.original_filename || 'Open PDF' %></a>
        </div>
      <% } %>

      <button class="w-full rounded-xl bg-[#0f6043] px-4 py-3 font-bold text-white hover:bg-[#063d2d]">
        <%= document ? 'Save Changes' : 'Upload Document' %>
      </button>
    </form>
  </main>
</body>
</html>
