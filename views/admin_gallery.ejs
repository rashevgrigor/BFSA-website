<!DOCTYPE html>
<html lang="bg">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Gallery Management | БФСА</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="min-h-screen bg-[#fbf8f1] text-[#26201c]">
  <header class="border-b bg-white/90 px-4 py-4 shadow-sm sm:px-6">
    <div class="mx-auto flex max-w-6xl flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
      <div>
        <h1 class="text-xl font-black text-[#063d2d] sm:text-2xl">Gallery Management</h1>
        <p class="text-sm text-gray-600">Logged in as <b><%= currentAdmin.name %></b></p>
      </div>
      <div class="flex flex-wrap items-center justify-center gap-2 sm:justify-end sm:gap-3">
        <a href="/admin" class="rounded-xl border px-4 py-2 font-bold text-[#063d2d]">Admin Dashboard</a>
        <a href="/admin/gallery/new" class="rounded-xl bg-[#0f6043] px-4 py-2 font-bold text-white">Create Album</a>
      </div>
    </div>
  </header>

  <main class="mx-auto max-w-6xl px-4 py-6 sm:px-6 sm:py-8">
    <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      <% if (!albums.length) { %>
        <div class="rounded-3xl bg-white p-8 text-center shadow-xl md:col-span-2 lg:col-span-3">
          <p class="text-gray-500">No gallery albums yet.</p>
          <a href="/admin/gallery/new" class="mt-4 inline-block rounded-xl bg-[#0f6043] px-5 py-3 font-bold text-white">Create first album</a>
        </div>
      <% } %>
      <% albums.forEach(album => { %>
        <article class="overflow-hidden rounded-3xl bg-white shadow-xl ring-1 ring-[#ead8b5]">
          <% if (album.cover_image) { %>
            <img src="<%= album.cover_image %>" class="h-48 w-full object-cover">
          <% } else { %>
            <div class="grid h-48 place-items-center bg-[#ead8b5] text-4xl font-black text-[#063d2d]">БФСА</div>
          <% } %>
          <div class="p-5">
            <h2 class="text-xl font-black text-[#063d2d]"><%= album.title %></h2>
            <p class="mt-1 text-sm text-gray-500"><%= album.photo_count || 0 %> photos</p>
            <p class="mt-3 line-clamp-3 text-sm text-gray-600"><%= album.description || '—' %></p>
            <div class="mt-5 flex flex-wrap gap-2">
              <a href="/gallery/<%= album.slug %>" target="_blank" class="rounded-lg border px-3 py-2 text-sm font-bold">View</a>
              <a href="/admin/gallery/<%= album.id %>/photos" class="rounded-lg bg-[#0f6043] px-3 py-2 text-sm font-bold text-white">Photos</a>
              <a href="/admin/gallery/<%= album.id %>/edit" class="rounded-lg border px-3 py-2 text-sm font-bold">Edit</a>
              <form action="/admin/gallery/<%= album.id %>/delete" method="POST" onsubmit="return confirm('Delete this album and all photos?')">
                <button class="rounded-lg border border-red-300 px-3 py-2 text-sm font-bold text-red-700">Delete</button>
              </form>
            </div>
          </div>
        </article>
      <% }) %>
    </div>
  </main>
</body>
</html>
