<!DOCTYPE html>
<html lang="bg">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Competition Management | БФСА</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="min-h-screen bg-[#fbf8f1] text-[#26201c]">
  <header class="border-b bg-white/90 px-4 py-4 shadow-sm sm:px-6">
    <div class="mx-auto flex max-w-6xl flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
      <div>
        <h1 class="text-xl font-black text-[#063d2d] sm:text-2xl">Competition Management</h1>
        <p class="text-sm text-gray-600">Logged in as <b><%= currentAdmin.name %></b></p>
      </div>
      <div class="flex flex-wrap items-center justify-center gap-2 sm:justify-end sm:gap-3">
        <a href="/admin" class="rounded-xl border px-4 py-2 font-bold text-[#063d2d]">Admin Dashboard</a>
        <a href="/admin/news" class="rounded-xl border px-4 py-2 font-bold text-[#063d2d]">News</a>
        <a href="/admin/competitions/new" class="rounded-xl bg-[#0f6043] px-4 py-2 font-bold text-white">Add Competition</a>
      </div>
    </div>
  </header>

  <main class="mx-auto max-w-6xl px-4 py-6 sm:px-6 sm:py-8">
    <div class="overflow-x-auto rounded-3xl bg-white shadow-xl">
      <table class="min-w-[760px] w-full text-left text-sm">
        <thead class="bg-[#063d2d] text-white">
          <tr>
            <th class="p-4">Poster</th>
            <th class="p-4">Competition</th>
            <th class="p-4">Dates</th>
            <th class="p-4">Location</th>
            <th class="p-4">Status</th>
            <th class="p-4">Actions</th>
          </tr>
        </thead>
        <tbody>
          <% if (!competitions.length) { %>
            <tr><td colspan="6" class="p-6 text-center text-gray-500">No competitions yet.</td></tr>
          <% } %>
          <% competitions.forEach(c => { %>
            <tr class="border-t align-middle">
              <td class="p-4">
                <% if (c.poster_path) { %>
                  <img src="<%= c.poster_path %>" class="h-16 w-24 rounded-lg object-cover">
                <% } else { %>
                  <div class="grid h-16 w-24 place-items-center rounded-lg bg-[#ead8b5] text-[#063d2d] font-bold">БФСА</div>
                <% } %>
              </td>
              <td class="p-4">
                <div class="font-black text-[#063d2d]"><%= c.title %></div>
                <div class="text-xs text-gray-500"><%= c.category %></div>
                <a href="/competitions/<%= c.slug %>" target="_blank" class="text-xs text-[#0f6043] hover:underline">View public page</a>
              </td>
              <td class="p-4"><%= c.start_date %><% if (c.end_date && c.end_date !== c.start_date) { %> – <%= c.end_date %><% } %></td>
              <td class="p-4"><%= [c.city, c.country].filter(Boolean).join(', ') || '—' %></td>
              <td class="p-4">
                <span class="rounded-full px-3 py-1 text-xs font-bold <%= c.status === 'upcoming' ? 'bg-green-50 text-green-700' : 'bg-gray-100 text-gray-600' %>"><%= c.status %></span>
              </td>
              <td class="p-4">
                <div class="flex gap-2">
                  <a href="/admin/competitions/<%= c.id %>/edit" class="rounded-lg border px-3 py-2 font-bold">Edit</a>
                  <form action="/admin/competitions/<%= c.id %>/delete" method="POST" onsubmit="return confirm('Delete this competition?')">
                    <button class="rounded-lg border border-red-300 px-3 py-2 font-bold text-red-700">Delete</button>
                  </form>
                </div>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </main>
</body>
</html>
