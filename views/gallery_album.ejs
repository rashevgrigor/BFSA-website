<!DOCTYPE html>
<html lang="bg">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= album.title %> | Галерия БФСА</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@600;700&family=Montserrat:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
  <style>body{font-family:Montserrat,sans-serif}.display{font-family:'Cormorant Garamond',serif}</style>
</head>
<body class="min-h-screen bg-[#fbf8f1] text-[#26201c]">
  <header class="border-b border-[#ead8b5] bg-white/80 px-5 py-5 backdrop-blur">
    <div class="mx-auto flex max-w-7xl items-center justify-between">
      <a href="/gallery" class="text-sm font-black uppercase tracking-[.16em] text-[#0f6043]">← Галерия</a>
      <a href="/" class="text-xl font-black text-[#063d2d] sm:text-2xl">БФСА</a>
    </div>
  </header>
  <main>
    <section class="relative overflow-hidden px-5 py-16 lg:px-8">
      <% if (album.cover_image) { %>
        <div class="absolute inset-0 opacity-15"><img src="<%= album.cover_image %>" class="h-full w-full object-cover"></div>
      <% } %>
      <div class="relative mx-auto max-w-5xl text-center">
        <p class="text-xs font-black uppercase tracking-[.2em] text-[#bd8e3b]">Фото албум</p>
        <h1 class="display mt-3 text-4xl sm:text-5xl font-bold uppercase text-[#063d2d]"><%= album.title %></h1>
        <% if (album.description) { %><p class="mx-auto mt-5 max-w-3xl leading-7 text-[#6e655e]"><%= album.description %></p><% } %>
        <p class="mt-5 text-sm font-bold text-[#0f6043]"><%= photos.length %> снимки</p>
      </div>
    </section>
    <section class="mx-auto max-w-7xl px-5 pb-16 lg:px-8">
      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        <% if (!photos.length) { %>
          <div class="rounded-3xl bg-white p-8 text-center shadow-xl sm:col-span-2 lg:col-span-3 text-[#6e655e]">Все още няма снимки в този албум.</div>
        <% } %>
        <% photos.forEach((photo, index) => { %>
          <button onclick="openLightbox('<%= photo.image_path %>')" class="group overflow-hidden rounded-2xl bg-white shadow-xl ring-1 ring-[#ead8b5]">
            <img src="<%= photo.image_path %>" class="h-72 w-full object-cover transition duration-500 group-hover:scale-105">
          </button>
        <% }) %>
      </div>
    </section>
  </main>
  <div id="lightbox" class="fixed inset-0 z-50 hidden bg-black/90 p-5" onclick="closeLightbox()">
    <button class="absolute right-6 top-4 sm:p-6 rounded-full bg-white px-4 py-2 font-black text-black">×</button>
    <div class="grid h-full place-items-center"><img id="lightboxImg" src="" class="max-h-full max-w-full rounded-xl object-contain"></div>
  </div>
  <script>
    function openLightbox(src){ document.getElementById('lightboxImg').src = src; document.getElementById('lightbox').classList.remove('hidden'); }
    function closeLightbox(){ document.getElementById('lightbox').classList.add('hidden'); }
  </script>
</body>
</html>
