<!DOCTYPE html>
<html lang="bg">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Галерия | БФСА</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@600;700&family=Montserrat:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
  <style>body{font-family:Montserrat,sans-serif}.display{font-family:'Cormorant Garamond',serif}</style>
</head>
<body class="min-h-screen bg-[#fbf8f1] text-[#26201c]">
  <header class="bg-[#063d2d] px-6 py-12 text-white">
    <div class="mx-auto max-w-7xl">
      <a href="/" class="inline-flex items-center rounded-xl border border-[#bd8e3b]/40 px-4 py-2 text-sm font-black text-[#ead8b5] transition hover:bg-white/10">
        <span class="sm:hidden">← Начало</span>
        <span class="hidden sm:inline">← Обратно към началната страница</span>
      </a>
      <p class="mt-8 text-xs font-black uppercase tracking-[.22em] text-[#bd8e3b]">БФСА</p>
      <h1 class="display mt-3 text-4xl sm:text-5xl font-bold uppercase tracking-wide md:text-6xl">Галерия</h1>
      <p class="mt-5 max-w-3xl text-white/75">Снимки и спомени от състезания, лагери и събития.</p>
    </div>
  </header>
  <main class="px-5 py-14 lg:px-8">
    <section class="mx-auto max-w-7xl">
      <div class="grid gap-7 md:grid-cols-2 lg:grid-cols-3">
        <% if (!albums.length) { %>
          <div class="rounded-3xl bg-white p-8 text-center shadow-xl md:col-span-2 lg:col-span-3 text-[#6e655e]">Все още няма качени албуми.</div>
        <% } %>
        <% albums.forEach(album => { %>
          <a href="/gallery/<%= album.slug %>" class="group overflow-hidden rounded-3xl bg-white shadow-xl ring-1 ring-[#ead8b5] transition hover:-translate-y-1 hover:shadow-2xl">
            <% if (album.cover_image) { %>
              <img src="<%= album.cover_image %>" class="h-64 w-full object-cover transition duration-500 group-hover:scale-105">
            <% } else { %>
              <div class="grid h-64 place-items-center bg-[#ead8b5] text-4xl sm:text-5xl font-black text-[#063d2d]">БФСА</div>
            <% } %>
            <div class="p-4 sm:p-6">
              <p class="text-xs font-black uppercase tracking-[.18em] text-[#bd8e3b]"><%= album.photo_count || 0 %> снимки</p>
              <h2 class="mt-2 text-2xl font-black text-[#063d2d]"><%= album.title %></h2>
              <p class="mt-3 line-clamp-3 text-sm leading-6 text-[#6e655e]"><%= album.description || 'Вижте албума.' %></p>
            </div>
          </a>
        <% }) %>
      </div>
    </section>
  </main>
</body>
</html>
