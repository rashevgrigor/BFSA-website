<!DOCTYPE html>
<html lang="bg">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin Dashboard | БФСА</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="min-h-screen bg-[#fbf8f1] text-[#26201c]">
  <header class="border-b bg-white/90 px-4 py-4 shadow-sm sm:px-6">
    <div class="mx-auto flex max-w-6xl flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
      <div>
        <h1 class="text-xl font-black text-[#063d2d] sm:text-2xl">Admin Dashboard</h1>
        <p class="text-sm text-gray-600">Logged in as <b><%= currentAdmin.name %></b> · <%= currentAdmin.role %></p>
      </div>
      <div class="flex flex-col gap-2 sm:flex-row sm:items-center">
      
        </form>
      </div>
    </div>
  </header>

  <main class="mx-auto grid max-w-6xl gap-6 px-4 py-6 sm:px-6 sm:py-8 lg:grid-cols-[1fr_380px]">
    <section class="lg:col-span-2">
      <div class="mb-4 flex flex-col gap-1">
        <p class="text-xs font-black uppercase tracking-[.22em] text-[#bd8e3b]">Админ панел</p>
        <h2 class="text-xl font-black text-[#063d2d] sm:text-2xl">Управление на сайта</h2>
      </div>
      <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-6">
        <a href="/admin/news" class="rounded-2xl bg-white p-4 text-center font-black text-[#063d2d] shadow ring-1 ring-[#ead8b5] transition hover:-translate-y-0.5 hover:shadow-lg">Новини</a>
        <a href="/admin/competitions" class="rounded-2xl bg-white p-4 text-center font-black text-[#063d2d] shadow ring-1 ring-[#ead8b5] transition hover:-translate-y-0.5 hover:shadow-lg">Състезания</a>
        <a href="/admin/documents" class="rounded-2xl bg-white p-4 text-center font-black text-[#063d2d] shadow ring-1 ring-[#ead8b5] transition hover:-translate-y-0.5 hover:shadow-lg">Документи</a>
        <a href="/admin/clubs" class="rounded-2xl bg-white p-4 text-center font-black text-[#063d2d] shadow ring-1 ring-[#ead8b5] transition hover:-translate-y-0.5 hover:shadow-lg">Клубове</a>
        <a href="/admin/gallery" class="rounded-2xl bg-white p-4 text-center font-black text-[#063d2d] shadow ring-1 ring-[#ead8b5] transition hover:-translate-y-0.5 hover:shadow-lg">Галерия</a>
        <a href="/admin/national-team" class="rounded-2xl bg-white p-4 text-center font-black text-[#063d2d] shadow ring-1 ring-[#ead8b5] transition hover:-translate-y-0.5 hover:shadow-lg">Нац. отбор</a>
      </div>
    </section>

    <section class="rounded-3xl bg-white p-4 shadow-xl sm:p-6">
      <h2 class="text-xl font-black text-[#063d2d]">Администраторски профили</h2>
      <div class="mt-5 overflow-x-auto rounded-2xl border">
        <table class="min-w-[680px] w-full text-left text-sm">
          <thead class="bg-[#063d2d] text-white">
            <tr><th class="p-3">Име</th><th class="p-3">Имейл</th><th class="p-3">Роля</th><th class="p-3">Действие</th></tr>
          </thead>
          <tbody>
            <% admins.forEach(admin => { %>
              <tr class="border-t">
                <td class="p-3 font-bold"><%= admin.name %></td>
                <td class="p-3"><%= admin.email %></td>
                <td class="p-3"><%= admin.role %></td>
                <td class="p-3">
                  <% if (currentAdmin.role === 'super_admin' && admin.id !== currentAdmin.id) { %>
                    <form action="/admin/profiles/<%= admin.id %>/delete" method="POST" onsubmit="return confirm('Delete this admin?')">
                      <button class="rounded-lg border border-red-300 px-3 py-1 text-red-700">Изтрий</button>
                    </form>
                  <% } else { %>
                    <span class="text-gray-400">—</span>
                  <% } %>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </section>

    <aside class="rounded-3xl bg-white p-4 shadow-xl sm:p-6">
      <h2 class="text-xl font-black text-[#063d2d]">Създай администратор</h2>
      <% if (currentAdmin.role !== 'super_admin') { %>
        <p class="mt-3 text-sm text-gray-600">Само super admins могат да създават профили.</p>
      <% } else { %>
        <% if (error) { %><div class="mt-4 rounded-xl bg-red-50 p-3 text-sm text-red-700"><%= error %></div><% } %>
        <form action="/admin/profiles" method="POST" class="mt-5 space-y-4">
          <input name="name" placeholder="Име" required class="w-full rounded-xl border p-3">
          <input name="email" type="email" placeholder="Имейл" required class="w-full rounded-xl border p-3">
          <input name="password" type="password" placeholder="Парола" required class="w-full rounded-xl border p-3">
          <select name="role" class="w-full rounded-xl border p-3">
            <option value="admin">Admin</option>
            <option value="super_admin">Super Admin</option>
          </select>
          <button class="w-full rounded-xl bg-[#0f6043] px-4 py-3 font-bold text-white transition hover:bg-[#063d2d]">Създай профил</button>
        </form>
      <% } %>
      <div class="mt-6 grid gap-3">
        <a href="/" class="rounded-xl border border-[#bd8e3b]/50 bg-[#fbf8f1] px-4 py-3 text-center font-bold text-[#063d2d] transition hover:bg-[#ead8b5]/40">
          Отвори сайта
        </a>
        <form action="/logout" method="POST">
          <button class="w-full rounded-xl bg-[#b81824] px-4 py-3 font-bold text-white transition hover:bg-[#8f121b]">
            Изход
          </button>
        </form>
      </div>
    </aside>
  </main>
</body>
</html>
