<!DOCTYPE html>
<html lang="bg">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Профил | БФСА</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="min-h-screen bg-[#fbf8f1] flex items-center justify-center px-4">
  <main class="w-full max-w-md rounded-3xl bg-white p-8 shadow-2xl border border-[#ead8b5]">
    <h1 class="text-2xl font-black text-[#063d2d] sm:text-3xl">Профил</h1>
    <p class="mt-2 text-sm text-gray-600">Информация за акаунта.</p>

    <div class="mt-6 rounded-2xl border bg-[#fffdf8] p-5 space-y-2">
      <p><b>Име:</b> <%= account.name %></p>
      <p><b>Email:</b> <%= account.email %></p>
      <p><b>Роля:</b> <%= account.role %></p>
    </div>

    <% if (isAdmin) { %>
      <a href="/admin" class="mt-5 block rounded-xl bg-[#0f6043] px-4 py-3 text-center font-bold text-white hover:bg-[#063d2d]">Админ панел</a>
    <% } %>

    <form action="/logout" method="POST" class="mt-4">
      <button class="w-full rounded-xl bg-[#b81824] px-4 py-3 font-bold text-white">Изход</button>
    </form>

    <a href="/" class="mt-5 inline-block text-sm text-[#0f6043] hover:underline">← Към сайта</a>
  </main>
</body>
</html>
