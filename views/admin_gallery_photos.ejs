<!DOCTYPE html>
<html lang="bg">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Album Photos | БФСА</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="min-h-screen bg-[#fbf8f1] text-[#26201c]">
  <header class="border-b bg-white/90 px-4 py-4 shadow-sm sm:px-6">
    <div class="mx-auto flex max-w-6xl flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
      <div>
        <h1 class="text-xl font-black text-[#063d2d] sm:text-2xl"><%= album.title %></h1>
        <p class="text-sm text-gray-600">Manage photos for this album</p>
      </div>
      <div class="flex flex-wrap items-center justify-center gap-2 sm:justify-end sm:gap-3">
        <a href="/admin/gallery" class="rounded-xl border px-4 py-2 font-bold text-[#063d2d]">Back to Gallery</a>
        <a href="/gallery/<%= album.slug %>" target="_blank" class="rounded-xl bg-[#bd8e3b] px-4 py-2 font-bold text-white">View Public Album</a>
      </div>
    </div>
  </header>

  <main class="mx-auto max-w-6xl px-4 py-6 sm:px-6 sm:py-8">
    <section class="rounded-3xl bg-white p-4 shadow-xl sm:p-6">
      <h2 class="text-xl font-black text-[#063d2d]">Upload Photos</h2>
      <form action="/admin/gallery/<%= album.id %>/photos" method="POST" enctype="multipart/form-data" class="mt-5 space-y-4">
        <input name="photos" type="file" accept="image/*" multiple required class="w-full rounded-xl border p-3">
        <p class="text-xs text-gray-500">You can upload multiple images at once. Maximum 20 images per upload.</p>
        <button class="rounded-xl bg-[#0f6043] px-5 py-3 font-bold text-white">Upload Photos</button>
      </form>
    </section>

    <section class="mt-8 grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
      <% if (!photos.length) { %>
        <div class="rounded-3xl bg-white p-8 text-center shadow-xl sm:col-span-2 lg:col-span-4 text-gray-500">No photos yet.</div>
      <% } %>
      <% photos.forEach(photo => { %>
        <article class="overflow-hidden rounded-2xl bg-white shadow-xl ring-1 ring-[#ead8b5]">
          <img src="<%= photo.image_path %>" class="h-48 w-full object-cover">
          <div class="p-4">
            <p class="text-sm text-gray-600"><%= photo.caption || '—' %></p>
            <form action="/admin/gallery/photos/<%= photo.id %>/delete" method="POST" class="mt-3" onsubmit="return confirm('Delete this photo?')">
              <button class="rounded-lg border border-red-300 px-3 py-2 text-sm font-bold text-red-700">Delete</button>
            </form>
          </div>
        </article>
      <% }) %>
    </section>
  </main>
</body>
</html>
