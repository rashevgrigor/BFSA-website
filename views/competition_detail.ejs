<!DOCTYPE html>
<html lang="bg">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= competition.title %> | БФСА</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="min-h-screen bg-[#fbf8f1] text-[#26201c]">
  <header class="relative overflow-hidden bg-[#063d2d] text-white">
    <% if (competition.poster_path) { %>
      <img src="<%= competition.poster_path %>" class="absolute inset-0 h-full w-full object-cover opacity-25">
    <% } %>
    <div class="relative mx-auto max-w-6xl px-6 py-14">
      <a href="/competitions" class="text-sm font-bold text-[#ead8b5] hover:underline">← Всички състезания</a>
      <div class="mt-8 max-w-3xl">
        <p class="text-xs font-black uppercase tracking-[.16em] text-[#ead8b5]"><%= competition.category %></p>
        <h1 class="mt-3 text-4xl font-black uppercase md:text-6xl"><%= competition.title %></h1>
        <p class="mt-4 text-lg text-white/80">📍 <%= [competition.venue, competition.city, competition.country].filter(Boolean).join(', ') || 'TBA' %></p>
        <p class="mt-1 text-lg text-white/80">📅 <%= competition.start_date %><% if (competition.end_date && competition.end_date !== competition.start_date) { %> – <%= competition.end_date %><% } %></p>
      </div>
    </div>
  </header>

  <main class="mx-auto grid max-w-6xl gap-8 px-6 py-10 lg:grid-cols-[1fr_360px]">
    <section class="rounded-3xl bg-white p-8 shadow-xl">
      <h2 class="text-xl font-black text-[#063d2d] sm:text-2xl">About the Event</h2>
      <% if (competition.short_description) { %><p class="mt-4 text-lg font-semibold text-gray-700"><%= competition.short_description %></p><% } %>
      <div class="prose mt-6 max-w-none whitespace-pre-line text-gray-700"><%= competition.description || 'More information will be published soon.' %></div>
    </section>

    <aside class="space-y-5">
      <div class="rounded-3xl bg-white p-4 shadow-xl sm:p-6">
        <h3 class="text-xl font-black text-[#063d2d]">Countdown</h3>
        <div id="countdown" data-date="<%= competition.start_date %>" class="mt-4 grid grid-cols-2 gap-3 text-center">
          <div class="rounded-xl bg-[#fbf8f1] p-4"><b id="days" class="block text-3xl text-[#0f6043]">—</b><span class="text-xs font-bold uppercase">days</span></div>
          <div class="rounded-xl bg-[#fbf8f1] p-4"><b id="hours" class="block text-3xl text-[#0f6043]">—</b><span class="text-xs font-bold uppercase">hours</span></div>
        </div>
        <% if (competition.status !== 'upcoming') { %><p class="mt-4 rounded-xl bg-gray-100 p-3 text-center font-bold text-gray-600">Competition finished</p><% } %>
      </div>

      <div class="rounded-3xl bg-white p-4 shadow-xl sm:p-6">
        <h3 class="text-xl font-black text-[#063d2d]">Event Links</h3>
        <div class="mt-4 space-y-3">
          <% if (competition.website_url) { %><a href="<%= competition.website_url %>" target="_blank" class="block rounded-xl border p-3 font-bold text-[#0f6043]">Official Website</a><% } %>
          <% if (competition.bulletin_path) { %><a href="<%= competition.bulletin_path %>" target="_blank" class="block rounded-xl border p-3 font-bold text-[#0f6043]">Bulletin / Information PDF</a><% } %>
          <% if (competition.live_stream_url) { %><a href="<%= competition.live_stream_url %>" target="_blank" class="block rounded-xl border p-3 font-bold text-[#0f6043]">Live Stream</a><% } %>
          <a href="/news" class="block rounded-xl border p-3 font-bold text-[#0f6043]">Related News</a>
        </div>
      </div>
    </aside>
  </main>

  <script>
    const target = new Date(document.getElementById('countdown').dataset.date + 'T09:00:00');
    const update = () => {
      const diff = target - new Date();
      if (diff <= 0) { document.getElementById('days').textContent = '0'; document.getElementById('hours').textContent = '0'; return; }
      document.getElementById('days').textContent = Math.floor(diff / 86400000);
      document.getElementById('hours').textContent = Math.floor((diff % 86400000) / 3600000);
    };
    update(); setInterval(update, 60000);
  </script>
</body>
</html>
